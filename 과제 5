#include <stdio.h>
#include <stdlib.h>

int main() {
    int N;
    printf("N x N 크기 입력: ");
    scanf("%d", &N);

    int **arr = (int **)malloc(sizeof(int *) * N);
    for (int i = 0; i < N; i++) {
        arr[i] = (int *)malloc(sizeof(int) * N);
    }

    int num = 1;
    // 대각선 개수는 총 2*N - 1개 (i + j의 최소값 0부터 최대값 2*N-2까지)
    for (int k = 0; k <= 2 * (N - 1); k++) {
        for (int i = 0; i < N; i++) {
            int j = k - i;
            if (j >= 0 && j < N) {
                arr[i][j] = num++;
            }
        }
    }

    // 출력
    for (int i = 0; i < N; i++) {
        for (int j = 0; j < N; j++) {
            printf("%2d ", arr[i][j]);
        }
        printf("\n");
    }

    for (int i = 0; i < N; i++) free(arr[i]);
    free(arr);
    return 0;
}
